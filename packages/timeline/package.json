{
  "name": "@pneuma-craft/timeline",
  "version": "0.4.0",
  "description": "Composition model — tracks, clips, time-based arrangement",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pneuma-craft/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandazki/pneuma-craft.git",
    "directory": "packages/timeline"
  },
  "homepage": "https://github.com/pandazki/pneuma-craft#readme",
  "bugs": {
    "url": "https://github.com/pandazki/pneuma-craft/issues"
  },
  "keywords": [
    "pneuma-craft",
    "timeline",
    "composition",
    "video-editing"
  ]
}
