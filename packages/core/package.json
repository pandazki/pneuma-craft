{
  "name": "@pneuma-craft/core",
  "version": "0.1.0",
  "description": "Domain model, asset registry, provenance graph, and event-sourced state protocol",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "vitest": "^3.1.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "dependencies": {
    "nanoid": "^5.1.7"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pandazki/pneuma-craft.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/pandazki/pneuma-craft#readme",
  "bugs": {
    "url": "https://github.com/pandazki/pneuma-craft/issues"
  },
  "keywords": [
    "pneuma-craft",
    "asset-registry",
    "provenance",
    "event-sourcing",
    "aigc"
  ]
}
